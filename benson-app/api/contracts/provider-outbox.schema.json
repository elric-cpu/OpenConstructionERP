{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bensonhomesolutions.com/contracts/provider-outbox.schema.json",
  "title": "Provider outbox payload",
  "type": "object",
  "required": ["schema_version", "event", "aggregate", "data"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,119}$" },
    "aggregate": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "minLength": 1, "maxLength": 80 },
        "id": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": false
    },
    "occurred_at": { "type": ["string", "null"], "format": "date-time" },
    "data": { "type": "object" }
  },
  "additionalProperties": false
}
