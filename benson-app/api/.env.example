BENSON_ENVIRONMENT=development
BENSON_WEBSITE_SIGNING_SECRET=replace-with-at-least-32-random-characters
BENSON_WEBSITE_SIGNATURE_MAX_AGE_SECONDS=300
BENSON_STAFF_GOOGLE_AUDIENCE=google-oauth-client-id.apps.googleusercontent.com
BENSON_STAFF_GOOGLE_DOMAIN=bensonhomesolutions.com
BENSON_OWNER_EMAILS=office@bensonhomesolutions.com
BENSON_ADMIN_EMAILS=
BENSON_OFFICE_EMAILS=
BENSON_ESTIMATOR_PM_EMAILS=
BENSON_ACCOUNTING_EMAILS=
BENSON_FIELD_EMAILS=
BENSON_FCC_BASE_URL=http://127.0.0.1:8082
BENSON_FCC_AUTH_TOKEN=replace-with-fcc-token
BENSON_FCC_MODEL=nvidia_nim/nvidia/nemotron-3-super-120b-a12b
BENSON_NOTIFICATION_WORKER_AUDIENCE=https://benson-operations-PROJECT_NUMBER.us-west1.run.app
BENSON_NOTIFICATION_WORKER_EMAIL=benson-notification-scheduler@PROJECT_ID.iam.gserviceaccount.com
BENSON_NOTIFICATION_EMAIL_TO=office@bensonhomesolutions.com
BENSON_NOTIFICATION_MAX_ATTEMPTS=10
BENSON_NOTIFICATION_BATCH_SIZE=25
BENSON_RESEND_API_KEY=replace-with-resend-api-key
BENSON_RESEND_FROM_EMAIL=Benson Home Solutions <leads@bensonhomesolutions.com>
# SMS is opt-in from authenticated owner settings and defaults off.
BENSON_SMS_ENABLED_DEFAULT=false
BENSON_TWILIO_ACCOUNT_SID=replace-with-account-sid
BENSON_TWILIO_API_KEY_SID=replace-with-api-key-sid
BENSON_TWILIO_API_KEY_SECRET=replace-with-api-key-secret
BENSON_TWILIO_FROM_NUMBER=+15415550100
BENSON_SMS_TO=+15415550101
BENSON_UPLOAD_BASE_URL=https://erp.bensonhomesolutions.com
BENSON_UPLOAD_STORAGE_PATH=/var/lib/benson/private-uploads
BENSON_UPLOAD_BUCKET=benson-operations-private-uploads
BENSON_UPLOAD_MAX_BYTES=15000000
BENSON_UPLOAD_SESSION_HOURS=72
BENSON_UPLOAD_SESSION_MAX_FILES=20
BENSON_UPLOAD_SESSION_MAX_BYTES=75000000
BENSON_DATABASE_PATH=/var/lib/benson/benson-operations.sqlite3
# Production must use PostgreSQL. SQLite is for local development and tests only.
BENSON_DATABASE_URL=postgresql://benson:replace-me@postgres:5432/benson_operations
BENSON_DDC_REGISTRY_PATH=skills/registry.json
BENSON_ACCOUNTING_PROVIDER_ENVIRONMENT=sandbox
BENSON_ACCOUNTING_PROVIDER_CLIENT_ID=
BENSON_ACCOUNTING_PROVIDER_CLIENT_SECRET=
